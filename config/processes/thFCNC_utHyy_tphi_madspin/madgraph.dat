# FCNC pp->tH model (u coupling, left-handed) -- production only, decayed by MadSpin
# Validation twin of thFCNC_utHyy_tphi: identical production + params, but the
# single-top cascade (t > b W, W inclusive) is applied by MadSpin instead of
# inline in the ME.
# References:
# https://arxiv.org/pdf/1712.02399
# Table 2 here: https://arxiv.org/pdf/2301.10486
import model MODEL_PLACEHOLDER/TopFCNC-onlyh

# Single top + Higgs; NO inline decays (see madspin_card.dat).
define mt = t t~
generate p p > mt h

output OUTPUT_PLACEHOLDER
launch

set nevents NEVENTS_PLACEHOLDER
set iseed SEED_PLACEHOLDER

PARAM_PLACEHOLDER/thFCNC_utH_tphi.dat
set param_card mass 25 125

set ebeam1 EBEAM_PLACEHOLDER
set ebeam2 EBEAM_PLACEHOLDER
