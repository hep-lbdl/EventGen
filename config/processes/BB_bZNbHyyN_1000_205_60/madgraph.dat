# MSSM sbottom sbottom model -- one branch -> H, other -> Z (inline ME decays)
# Symmetrised over which sbottom gives the Higgs, analogous to TT_tZNtHyyN.
# References:
# https://atlas.web.cern.ch/Atlas/GROUPS/PHYSICS/PAPERS/SUSY-2018-31/
# Current estimate of cross-section: xxx pb (LO only)
import model MSSM_SLHA2

# Define multiparticle labels
define susylq = ul ur dl dr cl cr sl sr
define susylq~ = ul~ ur~ dl~ dr~ cl~ cr~ sl~ sr~
# Specify process(es) to run
generate p p > b1 b1~ $ go susylq susylq~ b2 t1 t2 b2~ t1~ t2~, (b1 > b n2, n2 > h01 n1), (b1~ > b~ n2, n2 > z n1)
add process p p > b1 b1~ $ go susylq susylq~ b2 t1 t2 b2~ t1~ t2~, (b1 > b n2, n2 > z n1), (b1~ > b~ n2, n2 > h01 n1)

output OUTPUT_PLACEHOLDER
launch

set nevents NEVENTS_PLACEHOLDER
set iseed SEED_PLACEHOLDER

set param_card mass 25 125
set param_card mass 1000005 1000
set param_card mass 1000023 205
set param_card mass 1000022 60

set ebeam1 EBEAM_PLACEHOLDER
set ebeam2 EBEAM_PLACEHOLDER
