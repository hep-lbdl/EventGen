# MSSM chihchiw model
# References:
# https://arxiv.org/pdf/2004.10894
# Table 2 here: https://arxiv.org/pdf/2301.10486
# Current estimate of cross-section: 0.505 +- 6.799e-05 pb
import model MSSM_SLHA2

# Define multiparticle labels
define x1 = x1+ x1-

# Specify process(es) to run -- NO inline decays (cascade applied by MadSpin)
generate p p > x1 n2
add process p p > x1 n2 j
add process p p > x1 n2 j j

output OUTPUT_PLACEHOLDER
launch

set nevents NEVENTS_PLACEHOLDER
set iseed SEED_PLACEHOLDER

set param_card mass 25 125
set param_card mass 1000022 0.5
set param_card mass 1000023 300
set param_card mass 1000024 300
set param_card mass -1000024 300

set ebeam1 EBEAM_PLACEHOLDER
set ebeam2 EBEAM_PLACEHOLDER